/*
  Practica 2 - Jenkinsfile dummy (PUNTO DE PARTIDA)

  Este Jenkinsfile es intencionalmente simple. En la Practica 2 iras anadiendo
  piezas (stages, agents, funciones Groovy, Docker build, docker compose, etc.)
  hasta construir un pipeline CI/CD completo.
*/

// =========================
// Ejercicio 4 (Groovy): función reutilizable
// =========================
def runInDocker(String image, Closure body) {
  // TODO (E4): Ejecuta `body()` dentro del contenedor indicado usando Docker Pipeline:
  docker.image(image).inside { body() }
}

pipeline {
  agent any

  // =========================
  // Ejercicio 6.3 (parámetros)
  // =========================
  parameters {
    // TODO (E6.3): Añade un booleanParam RUN_CD (default false) para habilitar CD.
    booleanParam(name: 'RUN_CD', defaultValue: false, description: 'Ejecutar CD (solo develop/master)')

    // [E7] TODO: añade parámetro para push al registry.
    booleanParam(name: 'ENABLE_REGISTRY_PUSH', defaultValue: false, description: 'Publicar imagen en local-registry')

    // [E7/E12] TODO: añade parámetro para forzar uso de imagen del registry en CD.
    // booleanParam(name: 'USE_REGISTRY_IMAGE_IN_CD', defaultValue: true, description: 'Usar imagen del registry en CD')
  }


  // =========================
  // Ejercicio 6.4 (variables de entorno)
  // =========================
  environment {
    // TODO (E6.4): Define variables reutilizables:
    // - IMAGE_NAME (tag para docker build)
    // - IMAGE_VERSION (versión para docker build)
    // - APP_URL (endpoint para e2e)
    // - CI_IMAGE_NAME (imagen construida desde devops/ci.Dockerfile para usar `make`)
   
    IMAGE_VERSION = '0.0.3' 
    CI_IMAGE_NAME = "java-ci-tools:${env.BUILD_NUMBER}"
    APP_URL = 'http://localhost:8084/hello'
    VERSION_JAR = "${env.IMAGE_VERSION}-SNAPSHOT"
   
    // [E5] TODO: define repositorio local de imagen.
    IMAGE_REPO_LOCAL = 'scalian_training-java-hello-world'
    IMAGE_LOCAL = "${env.IMAGE_REPO_LOCAL}:${env.IMAGE_VERSION}"

    // - (opcional E7) REGISTRY y REGISTRY_CREDS_ID
    // [E7] TODO: define host/repo de registry y credencial Jenkins.
    REGISTRY_HOST = 'local-registry:5000'
    REGISTRY_REPO = 'scalian_training-java-hello-world'
    REGISTRY_CREDS_ID = 'local-registry-creds'
    IMAGE_REGISTRY = "${REGISTRY_HOST}/${REGISTRY_REPO}:${IMAGE_VERSION}"

  }



  // =========================
  // Ejercicio 1 (estructura básica)
  // =========================
  stages {  
    stage('Info') {
      steps {
        // TODO (E1): imprime JOB_NAME y BUILD_NUMBER
        echo "Job: ${env.JOB_NAME}"
        echo "Build: ${env.BUILD_NUMBER}"
      }
    }

    // =========================
    // Ejercicio 3 (preparación): construir imagen CI con make
    // =========================
    stage('CI - Build tools image') {
      steps {
        script {
          // TODO (E3): Construye una imagen de CI desde devops/ci.Dockerfile.
          // Ejemplo:
          // env.CI_IMAGE_NAME = "java-ci-tools:${env.BUILD_NUMBER}"
          // docker.build(env.CI_IMAGE_NAME, "-f devops/ci.Dockerfile .")
          docker.build(env.CI_IMAGE_NAME, "-f devops/ci.Dockerfile .")
        }
      }
    }

    // =========================
    // Ejercicio 3 (lint/test con Makefile) + Ejercicio 4 (refactor con runInDocker)
    // =========================
    stage('CI - Lint') {
      steps {
        script{
          runInDocker(env.CI_IMAGE_NAME) { sh 'make lint' }
        }
      }
    }

    stage('CI - Test') {
      steps {
         script{
          // TODO (E3/E4): Ejecuta `make lint` dentro de la imagen CI construida.
          runInDocker(env.CI_IMAGE_NAME) { sh 'make test' }
         }
      }
    }

     // =========================
     // Ejercicio 5 (docker build)
     // =========================
     stage('CI - Build image') {
      steps {
        script {
          // TODO (E5): Construye la imagen Docker usando el Dockerfile del repo:
          docker.build(env.IMAGE_LOCAL, "--build-arg VERSION=${env.VERSION_JAR} -f devops/Dockerfile .")
        }
      }
    }


    // =========================
    // Ejercicio 7 (opcional): push a registry privado
    // =========================
    stage('CI - Push image (opcional)') {
      when {
        // [E7] TODO: ejecuta solo si se habilita el parámetro.
        // TODO (E7): Ejecuta solo si has añadido un parámetro tipo ENABLE_REGISTRY_PUSH
        expression { return params.ENABLE_REGISTRY_PUSH }
      }
      steps {
        script {
          // TODO (E7): Taggea y pushea la imagen a local-registry:5000 usando credenciales Jenkins.
          // [E7] TODO: login + tag + push al registry.
          // Ejemplo:
          // withCredentials([usernamePassword(...)]) {
          //   sh '''
          //     echo "$REG_PASS" | docker login ...
          //     docker tag "$IMAGE_LOCAL" "$IMAGE_REGISTRY"
          //     docker push "$IMAGE_REGISTRY"
          //   '''
          // }

          withCredentials([usernamePassword(credentialsId: 'local-registry-creds',usernameVariable: "REG_USER", passwordVariable: "REG_PASS")]) {
             sh """
                echo "\$REG_PASS" | docker login ${env.REGISTRY_HOST} -u "\${REG_USER}" --password-stdin
                docker tag ${env.IMAGE_LOCAL} ${IMAGE_REGISTRY}
                docker push ${IMAGE_REGISTRY}

                # Comprobar los repositorios publicados
                curl -s http://localhost:5000/v2/_catalog

                # Comprobar tags de imagen
                curl -s http://localhost:5000/v2/${env.IMAGE_REPO_LOCAL}/tags/list

                # Validación final de comsumo
                docker pull localhost:5000/${env.IMAGE_LOCAL}
              """
             }
        }
      }
    }

    // =========================
    // Ejercicio 6 (compose) + Ejercicio 6.1 (solo develop/master) + Ejercicio 6.3 (RUN_CD)
    // =========================
     stage('CD') {
      when {
        anyOf {
          expression {return params.RUN_CD}
          branch 'develop'
          branch 'master'
        }
      }
      steps {
        echo "CD habilitado: RUN_CD=${params.RUN_CD}, branch=${env.BRANCH_NAME}"
        script {
           // [E6.2] TODO: calcular DEPLOY_ENV y COMPOSE_PROJECT.
           env.DEPLOY_ENV = (env.BRANCH_NAME == 'master') ? 'PRO' : 'DEV'
           env.COMPOSE_PROJECT = env.DEPLOY_ENV.toLowerCase()
          
           sh "docker compose -p ${env.COMPOSE_PROJECT} up -d" 
          
           sh 'sleep 5'
          
           // comprobar que el contenedor está arrancado
           sh 'docker ps'
           
           sh "docker compose -p ${env.COMPOSE_PROJECT} logs"
           
           try{
              // el curl fallará por un problema de networking y puertos
              // permitimos seguir con el pipeline -> 'SUCCESS'
              sh "curl ${env.APP_URL}"

           }catch(error){
              sh "echo ERROR:${error}"
              currentBuild.result = 'SUCCESS'
           }

          echo "Deploying to ${env.DEPLOY_ENV}"
        }
      }
      post{
        // =========================
        // Ejercicio 6.5 (hooks post)
        // =========================
        always {
          // Limpieza: esto debe ejecutarse tanto si falla como si va bien.
           sh "docker compose -p ${env.COMPOSE_PROJECT} down --volumes || true"
          
           // nombre de imagen en docker-compose-yml
           sh "docker rmi scalian_training-java-hello-world:0.0.2 || true"
        }
        success {
          echo 'SUCCESS'
        }
        failure {
          echo 'FAILURE'
          sh "docker compose -p ${env.COMPOSE_PROJECT} logs || true"
        }
        
      }
     }
  }
  post{
    always{
      //borrar imagen de docker build
      sh "docker rmi ${env.IMAGE_LOCAL} || true" 
     
      // borrar imagen de ci-lint y ci-test
      sh "docker rmi ${env.CI_IMAGE_NAME} || true"
    }
  }
}